# Supabase Configuration
# Copy this file to .env.local and fill in your actual Supabase project credentials

# Your Supabase project URL
# Get this from: Supabase Dashboard > Settings > API > Project URL
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key
# Get this from: Supabase Dashboard > Settings > API > Project API keys > anon public
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase service role key (for server-side operations)
# IMPORTANT: Never expose this in client-side code!
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Additional configuration
# REACT_APP_SUPABASE_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback